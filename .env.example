# Analytics (GoatCounter) is enabled by default with the public endpoint baked
# into src/lib/analytics.js, so no .env is needed in CI. Override here only to
# point at a different GoatCounter site, or set it to "" to disable analytics.
VITE_GOATCOUNTER_URL="https://sushan-adhikari.goatcounter.com/count"

# Optional EmailJS overrides for the contact form (sensible defaults are baked in).
# VITE_EMAILJS_SERVICE_ID=""
# VITE_EMAILJS_TEMPLATE_ID=""
# VITE_EMAILJS_PUBLIC_KEY=""
